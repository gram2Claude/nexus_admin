# Скопировать в .env.production на VPS и заполнить. Файл с секретами в репо не попадает.

# DSN ограниченной роли приложения (nexus_admin_app) — НЕ админский!
# В production админский fallback запрещён (src/lib/db.ts).
DATABASE_URL_APP=postgresql://nexus_admin_app.<ref>:<пароль>@<pooler-хост>:6543/postgres

# 64+ hex-символов: openssl rand -hex 48
AUTH_SECRET=

# Канонический адрес кабинета (без него Auth.js доверял бы Host-заголовку — ревью 2.1)
AUTH_URL=https://1-2-3-4.sslip.io
